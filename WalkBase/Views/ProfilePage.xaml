<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WalkBase.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:WalkBase.ViewModels"
    x:DataType="vm:ProfileViewModel"
    Title="Achievements"
    BackgroundColor="{StaticResource WbBg}">

    <ScrollView>
        <VerticalStackLayout Padding="12" Spacing="12">

            <!-- Headline stats -->
            <Border Style="{StaticResource WbCard}" Padding="18,16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="🏆 YOUR TOWN" Style="{StaticResource WbSection}" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="12" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="0">
                            <Label Text="{Binding Distance}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource WbGreen}" />
                            <Label Text="walked" Style="{StaticResource WbSection}" FontSize="10" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="0">
                            <Label Text="{Binding LifetimeSteps}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource WbText}" />
                            <Label Text="lifetime steps" Style="{StaticResource WbSection}" FontSize="10" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="0">
                            <Label Text="{Binding BuildingCount}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource WbText}" />
                            <Label Text="buildings" Style="{StaticResource WbSection}" FontSize="10" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="0">
                            <Label Text="{Binding BestStreak, StringFormat='🔥 {0}'}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource WbAmber}" />
                            <Label Text="best streak" Style="{StaticResource WbSection}" FontSize="10" />
                        </VerticalStackLayout>
                    </Grid>
                    <Label Text="{Binding Summary}" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource WbGreen}" />
                </VerticalStackLayout>
            </Border>

            <!-- Badge grid -->
            <CollectionView ItemsSource="{Binding Badges}" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:BadgeRow">
                        <Border Style="{StaticResource WbCard}" Padding="14" Opacity="{Binding Opacity}">
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="{Binding Emoji}" FontSize="34" HorizontalOptions="Center" />
                                <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource WbText}" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Description}" FontSize="11" TextColor="{StaticResource WbTextDim}" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Status}" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource WbGreen}" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
